{
  "version": "7.0.0-lumiverse.1",
  "name": "Megumin Suite",
  "identifier": "megumin_suite",
  "author": "KazumaONIISAN, Lumiverse port by Steve",
  "github": "https://github.com/Arif-salah/Megumin-Suite",
  "homepage": "https://github.com/Arif-salah/Megumin-Suite",
  "description": "Megumin Suite ported to Lumiverse: narrative engines, memory, NPC tracking, ban lists, story planning, and image generation.",
  "permissions": [
    "interceptor",
    "generation",
    "chat_mutation",
    "chats",
    "characters",
    "image_gen",
    "images",
    "ui_panels",
    "app_manipulation",
    "memories"
  ],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "minimum_lumiverse_version": "0.1.0",
  "storage_seed_files": [
    { "from": "img/", "to": "img/", "overwrite": false },
    { "from": "Screenshots/", "to": "Screenshots/", "overwrite": false }
  ],
  "interceptorTimeoutMs": 30000
}
